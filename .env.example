# Copia este archivo como referencia de las variables de entorno que
# necesita el asistente Cesarino. En Vercel NO subas un archivo .env:
# configura estas variables en Project Settings → Environment Variables.

# Obligatoria — tu API key de Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Opcional — modelo de Claude a usar. Si no se indica, se usa claude-opus-4-8.
# ANTHROPIC_MODEL=claude-opus-4-8
